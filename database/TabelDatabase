-- ACTUATORS
CREATE TABLE actuators (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    device_id BIGINT NOT NULL,
    actuator_code VARCHAR(50) NOT NULL UNIQUE,
    type VARCHAR(50) NOT NULL,
    is_active BOOLEAN NOT NULL DEFAULT 0,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- ANOMALY LOGS
CREATE TABLE anomaly_logs (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    sensor_reading_id BIGINT NOT NULL,
    sensor_type_id BIGINT NOT NULL,
    device_id BIGINT NOT NULL,
    value DECIMAL(10,4) NOT NULL,
    min_value DECIMAL(10,4) NOT NULL,
    max_value DECIMAL(10,4) NOT NULL,
    occurred_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    INDEX (device_id, occurred_at),
    INDEX (sensor_type_id, occurred_at)
);

-- ACTUATOR LOGS
CREATE TABLE actuator_logs (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    actuator_id BIGINT NOT NULL,
    anomaly_log_id BIGINT NULL,
    trigger_mode VARCHAR(20) NOT NULL,
    action VARCHAR(20) NOT NULL,
    executed_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    INDEX (actuator_id, executed_at)
);

-- NOTIFICATIONS
CREATE TABLE notifications (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    anomaly_log_id BIGINT NULL,
    actuator_log_id BIGINT NULL,
    message TEXT NOT NULL,
    is_read BOOLEAN NOT NULL DEFAULT 0,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    INDEX (is_read),
    INDEX (created_at)
);

